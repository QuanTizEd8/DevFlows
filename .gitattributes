# Normalize line endings: store text with LF and check it out with LF everywhere.
* text=auto eol=lf

# pixi.lock is machine-generated. Mark it generated so GitHub collapses its
# diffs by default and excludes it from repository language statistics.
pixi.lock linguist-generated=true

# NOTE: .github/workflows/*.yaml (and their .github/workflows/<id>/ support
# scripts) are generated by `devflows sync` from workflows/<id>/, but they are
# intentionally NOT marked linguist-generated. They are the consumer-facing
# published artifact, and reviewers must be able to see their full diffs in pull
# requests to confirm the generated output matches its source.

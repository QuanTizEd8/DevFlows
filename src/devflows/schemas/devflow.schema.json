{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://quantized8.github.io/DevFlows/schemas/devflow.schema.json",
  "title": "DevFlows workflow metadata",
  "description": "Schema for workflows/<id>/devflow.yaml catalog metadata.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "name", "status", "release"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$",
      "description": "Workflow identifier; must match the directory name."
    },
    "name": {
      "type": "string",
      "description": "Human-readable workflow name."
    },
    "summary": {
      "type": "string",
      "description": "One or two sentence description of the workflow."
    },
    "status": {
      "type": "string",
      "enum": ["active", "deprecated", "experimental"]
    },
    "owners": {
      "type": "array",
      "items": { "type": "string" }
    },
    "release": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "major"],
      "properties": {
        "type": {
          "type": "string",
          "description": "release-please release-type for this package (e.g. simple)."
        },
        "major": {
          "type": "integer",
          "minimum": 0,
          "description": "Current released major version line for this workflow, cross-validated against the major of its release-please manifest version. It is 0 while the workflow is pre-1.0 (the 0.x pre-completion contract); moving-major-tag automation and moving-major consumer references activate only once this reaches 1. Bump it to 1 in the same change that bumps the manifest baseline to 1.0.0."
        }
      }
    },
    "docs": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "category": { "type": "string" },
        "keywords": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "io": {
      "oneOf": [
        { "type": "boolean" },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "job": { "type": "string" },
            "runtime": { "type": "boolean" },
            "checkout": { "type": "boolean" },
            "artifact-download": { "type": "boolean" },
            "artifact-upload": { "type": "boolean" },
            "writeback": { "type": "boolean" },
            "runtime-jobs": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Additional runner jobs that also materialize the DevFlows runtime scripts."
            },
            "checkout-jobs": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Additional runner jobs that also receive the injected checkout channel step. Requires checkout: true. None may equal io.job."
            },
            "artifact-download-jobs": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Additional runner jobs that also receive the injected artifact-download channel step (granted actions: read). Requires artifact-download: true. None may equal io.job."
            }
          }
        }
      ]
    },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "examples": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "path"],
        "properties": {
          "name": { "type": "string" },
          "path": { "type": "string" }
        }
      }
    },
    "tests": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "scenarios": {
          "type": "array",
          "items": { "$ref": "#/$defs/scenario" }
        }
      }
    }
  },
  "$defs": {
    "fileEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path"],
      "properties": {
        "path": { "type": "string" },
        "content": { "type": "string" }
      }
    },
    "setupFileEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path"],
      "description": "A file placed into the checkout before the setup artifact is uploaded. Exactly one of content, source-path, or content-base64 supplies the bytes.",
      "properties": {
        "path": { "type": "string" },
        "content": {
          "type": "string",
          "description": "Inline UTF-8 text written to path."
        },
        "source-path": {
          "type": "string",
          "description": "Workspace-relative path (no '..') of a file in the checkout, copied verbatim to path. Use for binary or large payloads such as a prebuilt wheel."
        },
        "content-base64": {
          "type": "string",
          "description": "Base64-encoded bytes decoded and written to path. Use for small inline binary payloads."
        }
      },
      "oneOf": [
        { "required": ["content"] },
        { "required": ["source-path"] },
        { "required": ["content-base64"] }
      ]
    },
    "assertion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "file-exists",
            "file-contains",
            "workflow-output-equals",
            "branch-file-contains",
            "branch-file-missing",
            "latest-commit-message-equals"
          ]
        },
        "path": { "type": "string" },
        "text": { "type": "string" },
        "name": { "type": "string" },
        "value": { "type": ["string", "number", "boolean"] }
      }
    },
    "scenario": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "runs"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "name": { "type": "string" },
        "expect": {
          "type": "string",
          "enum": ["success", "failure"],
          "description": "Expected conclusion of the reusable-workflow call. 'success' (default) asserts the call succeeded. 'failure' is a negative-path scenario: the call job runs with continue-on-error so the run stays green while the assert job requires needs.<call>.result == 'failure' (RED if it unexpectedly succeeds). Expect-failure scenarios are hosted-only (act cannot reliably assert a failed reusable call) and declare no file/output assertions, because a failed call uploads no artifact. Matching a specific failure MESSAGE is intentionally unsupported: the failure originates in a nested reusable-call job whose logs cannot be reliably located (nested-job naming is undocumented) or fetched with the run's default actions:read token while the run is still in progress, so a log grep would be flaky. Assert specific validate-script messages with unit tests of the script instead."
        },
        "runs": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "enum": ["local", "hosted"] }
        },
        "cleanup": {
          "type": "array",
          "items": { "type": "string" }
        },
        "inputs": { "type": "object" },
        "artifact": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "name": { "type": "string" },
            "path": { "type": "string" }
          }
        },
        "setup-artifact": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "name": { "type": "string" },
            "path": { "type": "string" },
            "files": {
              "type": "array",
              "items": { "$ref": "#/$defs/setupFileEntry" }
            }
          }
        },
        "mutation": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "type": { "type": "string" },
            "branch-prefix": { "type": "string" },
            "fixture-path": { "type": "string" },
            "initial-files": {
              "type": "array",
              "items": { "$ref": "#/$defs/fileEntry" }
            }
          }
        },
        "writeback-payload": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "artifact-name": { "type": "string" },
            "paths": { "type": "array", "items": { "type": "string" } },
            "delete-paths": { "type": "array", "items": { "type": "string" } },
            "files": {
              "type": "array",
              "items": { "$ref": "#/$defs/fileEntry" }
            }
          }
        },
        "assertions": {
          "type": "array",
          "items": { "$ref": "#/$defs/assertion" }
        }
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://quantized8.github.io/DevFlows/schemas/devflow.schema.json",
  "title": "DevFlows workflow metadata",
  "description": "Schema for workflows/<id>/devflow.yaml catalog metadata.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "name", "status", "release"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$",
      "description": "Workflow identifier; must match the directory name."
    },
    "name": {
      "type": "string",
      "description": "Human-readable workflow name."
    },
    "summary": {
      "type": "string",
      "description": "One or two sentence description of the workflow."
    },
    "status": {
      "type": "string",
      "enum": ["active", "deprecated", "experimental"]
    },
    "owners": {
      "type": "array",
      "items": { "type": "string" }
    },
    "release": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "major"],
      "properties": {
        "type": { "type": "string" },
        "major": { "type": "integer", "minimum": 0 }
      }
    },
    "docs": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "category": { "type": "string" },
        "keywords": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "io": {
      "oneOf": [
        { "type": "boolean" },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "job": { "type": "string" },
            "runtime": { "type": "boolean" },
            "checkout": { "type": "boolean" },
            "artifact-download": { "type": "boolean" },
            "artifact-upload": { "type": "boolean" },
            "writeback": { "type": "boolean" },
            "runtime-jobs": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      ]
    },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "examples": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "path"],
        "properties": {
          "name": { "type": "string" },
          "path": { "type": "string" }
        }
      }
    },
    "tests": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "scenarios": {
          "type": "array",
          "items": { "$ref": "#/$defs/scenario" }
        }
      }
    }
  },
  "$defs": {
    "fileEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path"],
      "properties": {
        "path": { "type": "string" },
        "content": { "type": "string" }
      }
    },
    "assertion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "file-exists",
            "file-contains",
            "workflow-output-equals",
            "branch-file-contains",
            "branch-file-missing",
            "latest-commit-message-equals"
          ]
        },
        "path": { "type": "string" },
        "text": { "type": "string" },
        "name": { "type": "string" },
        "value": { "type": ["string", "number", "boolean"] }
      }
    },
    "scenario": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "runs", "assertions"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "name": { "type": "string" },
        "runs": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "enum": ["local", "hosted"] }
        },
        "cleanup": {
          "type": "array",
          "items": { "type": "string" }
        },
        "inputs": { "type": "object" },
        "artifact": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "name": { "type": "string" },
            "path": { "type": "string" }
          }
        },
        "setup-artifact": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "name": { "type": "string" },
            "path": { "type": "string" },
            "files": {
              "type": "array",
              "items": { "$ref": "#/$defs/fileEntry" }
            }
          }
        },
        "mutation": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "type": { "type": "string" },
            "branch-prefix": { "type": "string" },
            "fixture-path": { "type": "string" },
            "initial-files": {
              "type": "array",
              "items": { "$ref": "#/$defs/fileEntry" }
            }
          }
        },
        "writeback-payload": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "artifact-name": { "type": "string" },
            "paths": { "type": "array", "items": { "type": "string" } },
            "delete-paths": { "type": "array", "items": { "type": "string" } },
            "files": {
              "type": "array",
              "items": { "$ref": "#/$defs/fileEntry" }
            }
          }
        },
        "assertions": {
          "type": "array",
          "items": { "$ref": "#/$defs/assertion" }
        }
      }
    }
  }
}
